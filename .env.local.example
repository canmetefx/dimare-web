# Dimare Design — Local environment template
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.

# ── Sanity ───────────────────────────────────────────────────
# Public project info (exposed to browser, safe to commit)
NEXT_PUBLIC_SANITY_PROJECT_ID=0exrntll
NEXT_PUBLIC_SANITY_DATASET=production

# Write token — REQUIRED to run scripts/seed-*.mjs
# Create at https://sanity.io/manage → API → Tokens (role: Editor or Write)
# Never commit this. If leaked, revoke immediately in the same dashboard.
SANITY_WRITE_TOKEN=

# ── Optional overrides for seed scripts ──────────────────────
# SANITY_PROJECT_ID=0exrntll
# SANITY_DATASET=production
